# Biology Study Hub — Environment Variables
# Copy to .env and fill in your keys
# These go in Vercel Project Settings > Environment Variables

# DeepSeek API (文本任务：查词/解释/评分/RAG生成)
DEEPSEEK_API_KEY=sk-your-deepseek-key

# 智谱 GLM API
# 视觉 (glm-4.6v-flash, 免费模型) — 走标准 API: /api/paas/v4/chat/completions
GLM_VISION_4_6V_FLASH_API_KEY=your-glm-vision-key
# Embedding (embedding-3, 1024维) — 独立 key，方便单独管理额度
ZHIPU_EMBEDDING_API_KEY=your-zhipu-embedding-key

# Supabase (向量数据库 + Auth)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJ-your-service-key
